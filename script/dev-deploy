#!/usr/bin/env bash
# Build PostProd Tools and deploy the workspace, so you can test
# the distribution as a real user would experience it.
#
# This replaces bare `cargo build --release` as the standard dev workflow.
# After running, dashboard tool buttons, agent skills, and config extraction
# all work exactly like production.
#
# Usage:
#   ./script/dev-deploy              # build + deploy (incremental)
#   ./script/dev-deploy --run        # build + deploy + launch the app
#   ./script/dev-deploy --fresh      # wipe workspace first (first-install experience)
#   ./script/dev-deploy --skip-build # deploy only, skip cargo build
#
# Environment:
#   PROTOOLS_SDK_PATH  — path to PROTOOLS_SDK_PTSL repo
#                        (default: ~/Documents/Rust_projects/PROTOOLS_SDK_PTSL)
#   GO_PROJECT_PATH    — path to Go project repo (session-monitor)
#                        (default: ~/Documents/Go_project)
set -euo pipefail

SUITE_ROOT="$HOME/ProTools_Suite"
PTSL_SDK="${PROTOOLS_SDK_PATH:-$HOME/Documents/Rust_projects/PROTOOLS_SDK_PTSL}"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

fresh=false
skip_build=false
run_after=false
for arg in "$@"; do
    case "$arg" in
        --fresh) fresh=true ;;
        --skip-build) skip_build=true ;;
        --run) run_after=true ;;
        *) echo "Unknown flag: $arg"; exit 1 ;;
    esac
done

# --fresh: wipe workspace to simulate a first install
if [[ "$fresh" == true ]]; then
    echo "==> Wiping workspace (--fresh)..."
    rm -rf "$SUITE_ROOT"
fi

echo "==> Creating workspace directories..."
mkdir -p "$SUITE_ROOT/config"
mkdir -p "$SUITE_ROOT/tools/agent"
mkdir -p "$SUITE_ROOT/tools/runtime"

# --- Build ---
if [[ "$skip_build" == false ]]; then
    echo "==> Building postprod-ide (release)..."
    cargo build --release -p postprod-ide --manifest-path "$REPO_ROOT/Cargo.toml"
fi

# --- Agent tools (from target/agent/ — the organized deploy folder) ---
if [[ -d "$PTSL_SDK/target/agent" ]]; then
    echo "==> Syncing agent tools..."
    rsync -a --delete "$PTSL_SDK/target/agent/" "$SUITE_ROOT/tools/agent/"
    count=$(find "$SUITE_ROOT/tools/agent" -maxdepth 1 -type f -perm +111 | wc -l | tr -d ' ')
    echo "    $count agent tools deployed"
else
    echo "    Agent folder not found at $PTSL_SDK/target/agent — run deploy-agent.sh first"
fi

# --- Runtime tools ---
if [[ -d "$PTSL_SDK/target/runtime" ]]; then
    echo "==> Syncing runtime tools..."
    rsync -a --delete "$PTSL_SDK/target/runtime/" "$SUITE_ROOT/tools/runtime/"
fi

# --- Go session-monitor (replaces Rust version) ---
GO_PROJECT="${GO_PROJECT_PATH:-$HOME/Documents/Go_project}"
GO_SM="$GO_PROJECT/target/runtime/bin/Session_Monitor"
if [[ -f "$GO_SM/session-monitor" ]]; then
    echo "==> Syncing Go session-monitor..."
    rsync -a "$GO_SM/" "$SUITE_ROOT/tools/runtime/bin/Session_Monitor/"
    echo "    Go session-monitor deployed (replaces Rust)"
else
    echo "    Go session-monitor not found — run: cd $GO_PROJECT && ./deploy.sh"
fi

# --- Config defaults (only if missing — preserves user edits) ---
echo "==> Checking config defaults..."
for name in TOOLS.toml AGENTS.toml GUIDE.md; do
    dest="$SUITE_ROOT/config/$name"
    if [[ ! -f "$dest" ]]; then
        src="$REPO_ROOT/assets/config/$name"
        if [[ -f "$src" ]]; then
            cp "$src" "$dest"
            echo "    Extracted $name"
        fi
    else
        echo "    $name — preserved"
    fi
done

# --- Automations directory (one .toml per automation, only extract if missing) ---
AUTOMATIONS_SRC="$REPO_ROOT/assets/config/automations"
AUTOMATIONS_DST="$SUITE_ROOT/config/automations"
if [[ -d "$AUTOMATIONS_SRC" ]]; then
    mkdir -p "$AUTOMATIONS_DST"
    for f in "$AUTOMATIONS_SRC"/*.toml; do
        name=$(basename "$f")
        if [[ ! -f "$AUTOMATIONS_DST/$name" ]]; then
            cp "$f" "$AUTOMATIONS_DST/"
            echo "    Extracted $name"
        fi
    done
    echo "    automations/ — $(ls "$AUTOMATIONS_DST"/*.toml 2>/dev/null | wc -l | tr -d ' ') files"
fi

# --- Skill directory (progressive disclosure: SKILL.md + reference files) ---
SKILL_SRC="$REPO_ROOT/assets/config/skills/ptsl-tools"
SKILL_DST="$SUITE_ROOT/config/skills/ptsl-tools"
# When SKILL_SRC is a symlink to SKILL_DST (dev setup), they resolve to the
# same directory — copying would be a no-op or destructive.  Skip in that case.
SKILL_SRC_REAL="$(cd "$SKILL_SRC" 2>/dev/null && pwd -P)" || true
SKILL_DST_REAL="$(cd "$SKILL_DST" 2>/dev/null && pwd -P)" || true
if [[ -d "$SKILL_SRC" && "$SKILL_SRC_REAL" != "$SKILL_DST_REAL" ]]; then
    mkdir -p "$SKILL_DST"
    # SKILL.md: only copy if missing (user editable)
    if [[ ! -f "$SKILL_DST/SKILL.md" ]]; then
        cp "$SKILL_SRC/SKILL.md" "$SKILL_DST/"
        echo "    Extracted SKILL.md"
    else
        echo "    SKILL.md — preserved"
    fi
    # reference.md and workflows.md: always overwrite (not user-editable)
    for f in reference.md workflows.md; do
        cp "$SKILL_SRC/$f" "$SKILL_DST/"
    done
    echo "    Updated reference.md, workflows.md"
elif [[ -L "$SKILL_SRC" ]]; then
    echo "    skills/ptsl-tools — symlinked (skipping copy)"
fi

# --- .env template ---
env_example="$PTSL_SDK/templates/.env.example"
if [[ -f "$env_example" ]]; then
    cp "$env_example" "$SUITE_ROOT/config/.env.example"
    if [[ ! -f "$SUITE_ROOT/config/.env" ]]; then
        cp "$env_example" "$SUITE_ROOT/config/.env"
        echo "    Created .env from template"
    fi
fi

echo ""
echo "==> Dev deploy complete."
echo "    Binary:    $REPO_ROOT/target/release/postprod-ide"
echo "    Workspace: $SUITE_ROOT"

if [[ "$run_after" == true ]]; then
    echo ""
    echo "==> Launching postprod-ide..."
    exec "$REPO_ROOT/target/release/postprod-ide"
else
    echo ""
    echo "    Run: ./script/dev-deploy --run"
fi
