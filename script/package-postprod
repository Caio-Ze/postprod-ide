#!/usr/bin/env bash
# Build PostProd IDE and package everything into ~/PostProd_IDE/
# Optionally creates a distributable .tar.gz archive.
#
# Usage: ./script/package-postprod [--skip-build]
#
# Environment variables:
#   PROTOOLS_SDK_PATH  — path to PROTOOLS_SDK_PTSL repo (default: ~/Documents/Rust_projects/PROTOOLS_SDK_PTSL)
#   GO_PROJECT_PATH    — path to Go project repo (session-monitor) (default: ~/Documents/Go_project)
set -euo pipefail

SUITE_ROOT="$HOME/PostProd_IDE"
PTSL_SDK="${PROTOOLS_SDK_PATH:-$HOME/Documents/Rust_projects/PROTOOLS_SDK_PTSL}"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Version from git tag (v1.0.0 → 1.0.0), fallback to "dev"
RAW_VERSION=$(git -C "$REPO_ROOT" describe --tags --abbrev=0 2>/dev/null || echo "dev")
VERSION="${RAW_VERSION#v}"
ARCH="$(uname -m)"

skip_build=false
if [[ "${1:-}" == "--skip-build" ]]; then
    skip_build=true
fi

echo "==> PostProd Tools $VERSION ($ARCH)"

echo "==> Creating workspace directories..."
mkdir -p "$SUITE_ROOT/config/tools"
mkdir -p "$SUITE_ROOT/config/automations"
mkdir -p "$SUITE_ROOT/tools/agent"
mkdir -p "$SUITE_ROOT/tools/runtime"
mkdir -p "$SUITE_ROOT/deliveries"

if [[ "$skip_build" == false ]]; then
    echo "==> Building postprod-ide (release)..."
    cargo build --release -p postprod-ide --manifest-path "$REPO_ROOT/Cargo.toml"

    if [[ -d "$PTSL_SDK" ]]; then
        echo "==> Building agent-tools (release)..."
        cargo build --release -p agent-tools --manifest-path "$PTSL_SDK/Cargo.toml"
    else
        echo "    PTSL SDK not found at $PTSL_SDK — skipping agent tools build"
    fi
fi

# Copy agent tool binaries (release)
if [[ -d "$PTSL_SDK/target/release" ]]; then
    echo "==> Copying agent tool binaries..."
    for bin in "$PTSL_SDK/target/release/agent-"*; do
        [[ -f "$bin" && -x "$bin" ]] || continue
        cp "$bin" "$SUITE_ROOT/tools/agent/"
    done
    echo "    $(ls "$SUITE_ROOT/tools/agent/" | wc -l | tr -d ' ') agent tools installed"
fi

# Copy runtime via rsync (preserves internal structure)
if [[ -d "$PTSL_SDK/target/runtime" ]]; then
    echo "==> Syncing runtime tools..."
    rsync -a --delete "$PTSL_SDK/target/runtime/" "$SUITE_ROOT/tools/runtime/"
fi

# Go session-monitor (replaces Rust version in package)
GO_PROJECT="${GO_PROJECT_PATH:-$HOME/Documents/Go_project}"
GO_SM="$GO_PROJECT/target/runtime/bin/Session_Monitor"
if [[ -f "$GO_SM/session-monitor" ]]; then
    echo "==> Syncing Go session-monitor..."
    rsync -a "$GO_SM/" "$SUITE_ROOT/tools/runtime/bin/Session_Monitor/"
    echo "    Go session-monitor (replaces Rust)"
else
    echo "    WARNING: Go session-monitor not found at $GO_SM"
    echo "    Falling back to Rust session-monitor"
fi

echo "==> Done. Workspace at $SUITE_ROOT"
echo "    config/  — tool and automation TOMLs (user-managed, from product repos)"
echo "    tools/   — agent + runtime binaries"

# ---------------------------------------------------------------------------
# Create distributable archive
# ---------------------------------------------------------------------------

ARCHIVE_NAME="PostProdTools-${VERSION}-${ARCH}"
ARCHIVE_DIR="$REPO_ROOT/target/$ARCHIVE_NAME"
ARCHIVE_PATH="$REPO_ROOT/target/${ARCHIVE_NAME}.tar.gz"

echo ""
echo "==> Creating distributable archive..."

rm -rf "$ARCHIVE_DIR"
mkdir -p "$ARCHIVE_DIR/config/tools"
mkdir -p "$ARCHIVE_DIR/config/automations"
mkdir -p "$ARCHIVE_DIR/tools/agent"
mkdir -p "$ARCHIVE_DIR/tools/runtime"
mkdir -p "$ARCHIVE_DIR/deliveries"

# App binary
BINARY="$REPO_ROOT/target/release/postprod-ide"
if [[ -f "$BINARY" ]]; then
    cp "$BINARY" "$ARCHIVE_DIR/"
else
    echo "    WARNING: postprod-ide binary not found at $BINARY"
fi

# Agent tools
if [[ -d "$SUITE_ROOT/tools/agent" ]]; then
    for bin in "$SUITE_ROOT/tools/agent/agent-"*; do
        [[ -f "$bin" && -x "$bin" ]] || continue
        cp "$bin" "$ARCHIVE_DIR/tools/agent/"
    done
fi

# Runtime tools
if [[ -d "$SUITE_ROOT/tools/runtime" ]] && ls "$SUITE_ROOT/tools/runtime/"* >/dev/null 2>&1; then
    rsync -a "$SUITE_ROOT/tools/runtime/" "$ARCHIVE_DIR/tools/runtime/"
fi

# Create archive
tar -czf "$ARCHIVE_PATH" -C "$REPO_ROOT/target" "$ARCHIVE_NAME"
rm -rf "$ARCHIVE_DIR"

ARCHIVE_SIZE=$(du -h "$ARCHIVE_PATH" | cut -f1)
echo "==> Archive ready: $ARCHIVE_PATH ($ARCHIVE_SIZE)"
echo ""
echo "Install instructions:"
echo "  1. Extract:  tar xzf ${ARCHIVE_NAME}.tar.gz"
echo "  2. Clear quarantine:  xattr -cr ${ARCHIVE_NAME}/"
echo "  3. Copy binary to /Applications/ or ~/PostProd_IDE/"
echo "  4. Copy tools/ to ~/PostProd_IDE/tools/"
echo "  5. Install product configs from a product repo (e.g. postprod-protools)"
