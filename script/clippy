#!/usr/bin/env bash

set -euo pipefail

if [[ ! " $* " == *" -p "* && ! " $* " == *" --package "* ]]; then
    set -- "$@" --workspace
fi

set -x
"${CARGO:-cargo}" clippy "$@" --release --all-targets --all-features -- --deny warnings

# PostProd fork: workspace-crate-name collision check. Runs in local and CI.
# Placed before the GITHUB_ACTIONS aux-tool block because each `which <tool>
# || exit 0` below exits the entire script early when a dev-convenience tool
# is absent — if the collision check lived after them, it would be silently
# disabled on any dev machine missing cargo-machete/typos/buf. This is a
# correctness gate, not a dev-convenience tool, so it must run unconditionally.
# `if [ -x ]` runs when the script is present and executable, otherwise
# continues silently (e.g., pristine checkouts pre-install).
# See private/specs/workspace-crate-collision-check.md.
if [ -x "$(dirname "$0")/postprod/check-workspace-crate-collisions" ]; then
    "$(dirname "$0")/postprod/check-workspace-crate-collisions"
fi

# If local, run other checks if we have the tools installed.
if [[ -z "${GITHUB_ACTIONS+x}" ]]; then
    which cargo-machete >/dev/null 2>&1 || exit 0
    cargo machete

    which typos >/dev/null 2>&1 || exit 0
    typos --config typos.toml

    which buf >/dev/null 2>&1 || exit 0
    buf lint crates/proto/proto
    buf format --diff --exit-code crates/proto/proto
fi
